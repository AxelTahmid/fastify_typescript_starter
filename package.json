{
    "name": "fastifystarter",
    "version": "2.0.0",
    "description": "Fastify starter template with TypeScript, Kysely, pg-boss, and Docker tooling",
    "type": "module",
    "author": "AxelTahmid",
    "license": "Apache-2.0",
    "packageManager": "yarn@4.9.1",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
        "start": "npx tsx src/server.ts",
        "dev": "npx tsx watch --clear-screen=false src/server.ts",
        "test": "yarn build && node --test --test-isolation=none \"dist/**/*.test.js\"",
        "migrate": "make db-migrate",
        "db:types": "make db-types",
        "check": "yarn exec biome check .",
        "format": "yarn exec biome check --write .",
        "deps": "yarn upgrade-interactive",
        "release": "standard-version"
    },
    "dependencies": {
        "@fastify/basic-auth": "^6.2.0",
        "@fastify/cors": "^11.2.0",
        "@fastify/formbody": "^8.0.2",
        "@fastify/helmet": "^13.0.2",
        "@fastify/jwt": "^10.0.0",
        "@fastify/multipart": "^9.4.0",
        "@fastify/sensible": "^6.0.4",
        "@fastify/swagger": "^9.7.0",
        "@fastify/under-pressure": "^9.0.3",
        "@scalar/fastify-api-reference": "^1.48.0",
        "bcryptjs": "^3.0.3",
        "close-with-grace": "^2.5.0",
        "dotenv": "^17.3.1",
        "fastify": "^5.8.2",
        "fastify-plugin": "^5.1.0",
        "kysely": "^0.28.11",
        "minio": "^8.0.7",
        "nodemailer": "^8.0.1",
        "ofetch": "^1.5.1",
        "pg": "^8.20.0",
        "pg-boss": "^12.14.0",
        "typebox": "^1.1.6"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.6",
        "@fastify/type-provider-typebox": "^6.1.0",
        "@types/node": "^25.3.5",
        "@types/nodemailer": "^7.0.11",
        "@types/pg": "^8.18.0",
        "kysely-codegen": "^0.20.0",
        "lefthook": "^2.1.3",
        "pino-pretty": "^13.1.3",
        "standard-version": "^9.5.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
